# Postgres
DATABASE_URL=postgresql+psycopg://rag_chatbot:rag_chatbot_dev@localhost:5432/rag_chatbot

# API auth
API_KEY=changeme-dev-key

# Azure AI Search
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_API_KEY=
AZURE_SEARCH_INDEX_NAME=rag-chatbot-chunks

# Azure OpenAI (embeddings; optionally generation)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-10-21

# Azure AI Foundry (model-inference API -- DeepSeek or another
# serverless/MaaS deployment; the full "Target URI" from Azure AI
# Foundry's deployment page, including request path + api-version)
AZURE_AI_FOUNDRY_ENDPOINT=
AZURE_AI_FOUNDRY_API_KEY=
AZURE_AI_FOUNDRY_MODEL=DeepSeek-V3.2

# Generation provider: "claude", "azure_openai", or "deepseek" -- the
# default when a chat request doesn't specify one; GET /api/v1/models
# reports which providers have credentials configured.
GENERATION_PROVIDER=claude
ANTHROPIC_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=

# Retrieval tuning (see docs/plan.md Decisions Register; threshold
# calibrated in Phase 8, docs/phase-8.md)
RETRIEVAL_CANDIDATE_COUNT=20
RETRIEVAL_TOP_K=5
REFUSAL_RERANKER_THRESHOLD=2.6

# Logging
LOG_LEVEL=INFO
